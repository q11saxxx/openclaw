# 本文件说明：忽略开发产生的缓存、构建产物、虚拟环境与数据库文件。
node_modules/
dist/
.vite/
.venv/
__pycache__/
*.pyc
.env
*.sqlite3
*.db
coverage/
.pytest_cache/
backend/.mypy_cache/
frontend/.turbo/
data/uploads/*
!data/uploads/.gitkeep
data/reports/*
!data/reports/.gitkeep
data/cache/*
!data/cache/.gitkeep
data/trivy/*
!data/trivy/.gitkeep
